{
  "name": "librl",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel serve watch:c:wasm watch:remote:wasm",
    "serve": "vite",
    "build:remote:wasm": "make -C examples/remote wasm",
    "watch:remote:wasm": "onchange \"src/**/*.c\" \"src/**/*.h\" \"include/**/*.h\" \"examples/remote/**/*.c\" \"examples/remote/**/*.h\" --exclude \"examples/remote/out/**\" -- npm run build:remote:wasm",
    "build:c:wasm": "make -C examples/c wasm",
    "watch:c:wasm": "onchange \"src/**/*.c\" \"src/**/*.h\" \"include/**/*.h\" \"examples/c/**/*.c\" \"examples/c/**/*.h\" --exclude \"examples/c/out/**\" -- npm run build:c:wasm",
    "gen:chrome-devtools-workspace": "python3 tools/generate_devtools_workspace.py",
    "install": "npm run gen:chrome-devtools-workspace"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "dotenv": "^17.3.1",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "vite": "^7.3.1"
  }
}
